@model Pedidos360.Models.Cliente

@{
    ViewData["Title"] = "Detalle Cliente";
}

<h2>Detalle Cliente</h2>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <dt class="col-sm-4">Cédula</dt>
            <dd class="col-sm-8">@Model.Cedula</dd>

            <dt class="col-sm-4">Correo</dt>
            <dd class="col-sm-8">@Model.Correo</dd>

            <dt class="col-sm-4">Teléfono</dt>
            <dd class="col-sm-8">@Model.Telefono</dd>

            <dt class="col-sm-4">Dirección</dt>
            <dd class="col-sm-8">@Model.Direccion</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>