@model IEnumerable<Pedidos360.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h2>Productos</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Nuevo Producto</a>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control" placeholder="Buscar por nombre..." />
    </div>
    <div class="col-md-4">
        <select name="categoriaId" class="form-select" asp-items="ViewBag.Categorias">
            <option value="">-- Todas las categorías --</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Categoria?.Nombre</td>
                <td>@item.Precio.ToString("C")</td>
                <td>@item.Stock</td>
                <td>@(item.Activo ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>