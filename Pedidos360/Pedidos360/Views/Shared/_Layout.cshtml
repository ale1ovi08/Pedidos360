<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sweet360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
            :root {
                --pink-primary: #F48FB1;
                --pink-light: #FCE4EC;
                --pink-soft: #FFF5F8;
                --pink-dark: #E91E8C;
                --pink-navbar: #FADADD;
                --gold: #F6C97A;
                --dark: #5D4157;
                --text-muted-pink: #B07A95;
            }

            body {
                font-family: 'Poppins', sans-serif;
                background-color: #FFF9FB;
                color: var(--dark);
            }

            .navbar-sweet {
                background: #FADADD;
                box-shadow: 0 2px 15px rgba(244, 143, 177, 0.2);
                padding: 0.8rem 1.5rem;
                border-bottom: 2px solid #F8BBD9;
            }

            .navbar-brand-sweet {
                font-family: 'Playfair Display', serif;
                font-size: 1.6rem;
                font-weight: 700;
                color: #C2185B !important;
                letter-spacing: 1px;
            }

            .navbar-brand-sweet span {
                color: #F6A5C0;
            }

            .nav-link-sweet {
                color: #C2185B !important;
                font-weight: 500;
                font-size: 0.9rem;
                padding: 0.5rem 1rem !important;
                border-radius: 20px;
                transition: all 0.3s;
            }

            .nav-link-sweet:hover {
                background: #F8BBD9;
                color: #880E4F !important;
            }

            .nav-link-sweet i {
                margin-right: 6px;
            }

            .main-content {
                padding: 2rem 0;
                min-height: calc(100vh - 160px);
            }

            .card {
                border: 1px solid #F8BBD9;
                border-radius: 16px;
                box-shadow: 0 4px 20px rgba(244, 143, 177, 0.1);
                background: white;
            }

            .btn-primary {
                background: #F48FB1;
                border: none;
                border-radius: 25px;
                padding: 0.5rem 1.5rem;
                font-weight: 500;
                color: white;
                transition: all 0.3s;
            }

            .btn-primary:hover {
                background: #EC407A;
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(244, 143, 177, 0.4);
                color: white;
            }

            .btn-warning {
                background: #F6C97A;
                border: none;
                border-radius: 25px;
                color: white;
                font-weight: 500;
            }

            .btn-warning:hover {
                background: #F0A500;
                color: white;
            }

            .btn-danger {
                border-radius: 25px;
                font-weight: 500;
            }

            .btn-info {
                border-radius: 25px;
                font-weight: 500;
                background: #B2EBF2;
                border: none;
                color: #00838F;
            }

            .btn-secondary {
                border-radius: 25px;
                font-weight: 500;
                background: #F3E5F5;
                border: none;
                color: #7B1FA2;
            }

            .table {
                border-radius: 12px;
                overflow: hidden;
            }

            .table thead th {
                background: #FADADD;
                color: #C2185B;
                border: none;
                font-weight: 600;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 1rem;
                border-bottom: 2px solid #F8BBD9;
            }

            .table tbody tr {
                transition: all 0.2s;
                border-bottom: 1px solid #FCE4EC;
            }

            .table tbody tr:hover {
                background-color: #FFF5F8;
            }

            .form-control, .form-select {
                border-radius: 12px;
                border: 2px solid #F8BBD9;
                padding: 0.6rem 1rem;
                transition: all 0.3s;
                background: #FFFAFB;
            }

            .form-control:focus, .form-select:focus {
                border-color: #F48FB1;
                box-shadow: 0 0 0 0.2rem rgba(244, 143, 177, 0.2);
            }

            .form-label {
                font-weight: 600;
                color: #AD1457;
                font-size: 0.9rem;
            }

            h2 {
                font-family: 'Playfair Display', serif;
                color: #AD1457;
                font-weight: 700;
                margin-bottom: 1.5rem;
            }

            .footer-sweet {
                background: #FADADD;
                color: #AD1457;
                padding: 1rem 0;
                text-align: center;
                font-size: 0.85rem;
                border-top: 2px solid #F8BBD9;
            }

            .footer-sweet a {
                color: #E91E8C;
            }

            .page-header {
                background: linear-gradient(135deg, #FCE4EC, #F8BBD9);
                border-radius: 16px;
                padding: 1.5rem 2rem;
                margin-bottom: 1.5rem;
                border: 1px solid #F48FB1;
            }

            .page-header h2 {
                margin-bottom: 0;
                color: #AD1457;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-sweet">
            <div class="container-fluid">
                <a class="navbar-brand-sweet" asp-area="" asp-controller="Home" asp-action="Index">
                    Sweet<span>360</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link-sweet" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-sweet" asp-controller="Productos" asp-action="Index">
                                <i class="bi bi-box-seam"></i> Productos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-sweet" asp-controller="Clientes" asp-action="Index">
                                <i class="bi bi-people"></i> Clientes
                            </a>
                        </li>
                    </ul>
                    <span style="color:#AD1457; font-size:0.85rem; font-weight:500;">
                        🍰 Pastelería Gourmet
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-sweet">
        <div class="container">
            &copy; 2026 - Sweet360 Pastelería Gourmet - Grupo #6
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>